# OS
.DS_Store
Thumbs.db

# Logs
*.log
error_log

# Build tooling — installed by `cd assets && npm install`, never edited by hand
assets/node_modules/
npm-debug.log*

# PHP dev tooling — installed by `composer install` (phpcs + WPCS; see
# phpcs.xml.dist and the pre-commit hook). Not needed at runtime.
vendor/

# Editor
.vscode/
.idea/

# Note: dist/ (compiled CSS/JS) IS committed on purpose — this theme deploys
# straight to shared hosting with no build step in the deploy pipeline, so the
# compiled output has to ship in the repo. Run `gulp build` before committing
# any change under assets/ so dist/ stays in sync.
